{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "tools4care (main app)",
      "runtimeExecutable": "/bin/bash",
      "runtimeArgs": [".claude/start-dev.sh"],
      "port": 5173,
      "autoPort": true
    },
    {
