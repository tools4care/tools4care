# ==============================================
# TOOLS4CARE - ENVIRONMENT VARIABLES EXAMPLE
# Copy this file to .env and fill in the values
# NEVER commit .env to git
# ==============================================

# ----------------------------------------------
# SUPABASE CONFIGURATION
# ----------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SB_FUNCTIONS_URL=
VITE_SUPABASE_SERVICE_KEY=

# ----------------------------------------------
# STRIPE CONFIGURATION
# ----------------------------------------------
VITE_STRIPE_PUBLISHABLE_KEY=

# ----------------------------------------------
# EMAIL CONFIGURATION
# ----------------------------------------------
VITE_EMAIL_MODE=edge
VITE_COMPANY_EMAIL=
VITE_ADMIN_EMAIL=
VITE_COMPANY_NAME=

# ----------------------------------------------
# CXC ADMIN SECRET (Cuentas por Cobrar admin unlock)
# Set this in Vercel: Settings → Environment Variables → VITE_CXC_SECRET
# ----------------------------------------------
VITE_CXC_SECRET=

# ----------------------------------------------
# CXC API CONFIGURATION
# ----------------------------------------------
VITE_CXC_API=http://127.0.0.1:8000
VITE_CXC_API_BASE=

# ----------------------------------------------
# SENTRY MONITORING
# ----------------------------------------------
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1

# ----------------------------------------------
# MONITORING / ANALYTICS
# ----------------------------------------------
VITE_PUBLIC_APP_URL=https://tools4care.vercel.app
VITE_VERCEL_ANALYTICS_ENABLED=true
VITE_SENTRY_DASHBOARD_URL=https://tools4caregmailcom.sentry.io/issues/
VITE_BETTERSTACK_DASHBOARD_URL=https://uptime.betterstack.com/team/t565742/monitors
VITE_VERCEL_ANALYTICS_URL=https://vercel.com/edwins-projects-5abac2e2/tools4care/analytics
VITE_SUPABASE_DASHBOARD_URL=https://supabase.com/dashboard/project/gvloygqbavibmpakzdma
