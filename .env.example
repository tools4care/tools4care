# ==============================================
# TOOLS4CARE - ENVIRONMENT VARIABLES EXAMPLE
# Copy this file to .env and fill in the values
# NEVER commit .env to git
# ==============================================

# ----------------------------------------------
# SUPABASE CONFIGURATION
# ----------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SB_FUNCTIONS_URL=
VITE_SUPABASE_SERVICE_KEY=

# ----------------------------------------------
# STRIPE CONFIGURATION
# ----------------------------------------------
VITE_STRIPE_PUBLISHABLE_KEY=

# ----------------------------------------------
# EMAIL CONFIGURATION
# ----------------------------------------------
VITE_EMAIL_MODE=edge
VITE_COMPANY_EMAIL=
VITE_ADMIN_EMAIL=
VITE_COMPANY_NAME=

# ----------------------------------------------
# CXC ADMIN SECRET (Cuentas por Cobrar admin unlock)
# Set this in Vercel: Settings → Environment Variables → VITE_CXC_SECRET
# ----------------------------------------------
VITE_CXC_SECRET=

# ----------------------------------------------
# CXC API CONFIGURATION
# ----------------------------------------------
VITE_CXC_API=http://127.0.0.1:8000
VITE_CXC_API_BASE=
